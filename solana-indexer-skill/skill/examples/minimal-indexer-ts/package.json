    "migrate": "node --import tsx migrate.ts"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helius-sdk": "^3.0.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
