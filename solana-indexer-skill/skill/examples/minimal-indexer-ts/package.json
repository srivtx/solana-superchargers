{
  "name": "minimal-indexer",
  "version": "0.1.0",
  "description": "100-line Solana indexer: Helius webhook → Postgres. Runnable against devnet.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "tsx watch index.ts",
    "start": "tsx index.ts",
